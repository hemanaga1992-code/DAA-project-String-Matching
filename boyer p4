if __name__ == "__main__":
    sample_text = (
        "Pattern matching is a fundamental technique in computer science. "
        "Pattern matching helps search engines locate relevant content. "
        "Efficient pattern matching reduces computation time significantly."
    )
    search_pattern = "pattern matching"

    print("=" * 60)
    print("  BOYER–MOORE ALGORITHM  (Bad Char + Good Suffix)")
    print("=" * 60)
    print(f"\n  Text    : {sample_text[:60]}...")
    print(f"  Pattern : '{search_pattern}'")
    print("-" * 60)

    print_bad_char_table(search_pattern.lower())

    result = boyer_moore_search(sample_text, search_pattern, case_sensitive=False)

    print(f"\n  Total Matches  : {result['total_matches']}")
    print(f"  Positions      : {result['positions']}")
    print(f"  Comparisons    : {result['comparisons']}")
    print(f"  Chars Skipped  : {result['skips']}  (heuristic savings)")
    print(f"\n  Time Complexity : O(n/m) best  |  O(n × m) worst  where n={len(sample_text)}, m={len(search_pattern)}")

    print("\n--- Highlighted Text ---")
    highlighted = highlight_matches(
        sample_text.lower(), search_pattern.lower(), result["positions"]
    )
    print(highlighted)
    print("=" * 60)
